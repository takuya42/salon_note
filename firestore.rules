rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSalonAdmin(shopId) {
      return signedIn()
        && exists(/databases/$(database)/documents/shops/$(shopId))
        && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    function hasOnlyShopFields() {
      return request.resource.data.keys().hasOnly([
        'shopId',
        'shopName',
        'name',
        'description',
        'address',
        'phone',
        'imageUrl',
        'imagePath',
        'imageBucket',
        'businessHours',
        'instagramUrl',
        'lineUrl',
        'websiteUrl',
        'externalLinkTitle',
        'externalLinkUrl',
        'paymentMethods',
        'ownerId',
        'ownerEmail',
        'planType',
        'isWebPublished',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasOnlyUpdatedShopFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'shopId',
        'shopName',
        'name',
        'description',
        'address',
        'phone',
        'imageUrl',
        'imagePath',
        'imageBucket',
        'businessHours',
        'instagramUrl',
        'lineUrl',
        'websiteUrl',
        'externalLinkTitle',
        'externalLinkUrl',
        'paymentMethods',
        'ownerId',
        'ownerEmail',
        'planType',
        'isWebPublished',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasOnlyMenuFields() {
      return request.resource.data.keys().hasOnly([
        'menuId',
        'shopId',
        'name',
        'price',
        'duration',
        'description',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasOnlyReservationFields() {
      return request.resource.data.keys().hasOnly([
        'reservationId',
        'shopId',
        'menuId',
        'customerName',
        'customerPhone',
        'customerEmail',
        'reservationDateTime',
        'status',
        'source',
        'isNotified',
        'createdAt',
        'name',
        'start',
        'end',
        'phone',
        'menu',
        'price',
        'duration',
        'date'
      ]);
    }

    function isShopWebPublished(shopId) {
      return exists(/databases/$(database)/documents/shops/$(shopId))
        && get(/databases/$(database)/documents/shops/$(shopId)).data.isWebPublished == true;
    }

    function isValidReservationCreate() {
      return hasOnlyReservationFields()
        && request.resource.data.shopId is string
        && request.resource.data.menuId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string
        && request.resource.data.customerEmail is string
        && request.resource.data.customerEmail.size() > 0
        && request.resource.data.reservationDateTime is timestamp
        && request.resource.data.status == 'pending'
        && request.resource.data.source in ['web', 'app', 'line']
        && (
          (request.resource.data.source == 'web'
            && isShopWebPublished(request.resource.data.shopId))
          || (request.resource.data.source != 'web' && signedIn())
        )
        && request.resource.data.isNotified == false
        && request.resource.data.name is string
        && request.resource.data.start is timestamp
        && request.resource.data.end is timestamp
        && request.resource.data.phone is string
        && request.resource.data.menu is string
        && request.resource.data.price is int
        && request.resource.data.duration is int
        && request.resource.data.date is timestamp
        && request.resource.data.start == request.resource.data.reservationDateTime
        && request.resource.data.date == request.resource.data.reservationDateTime;

    }

    match /shops/{shopId} {
      // Public web pages may only read published shops. Owners retain access
      // to their own unpublished shop from the authenticated management app.
      allow read: if resource.data.isWebPublished == true
        || (signedIn() && resource.data.ownerId == request.auth.uid);

      allow create: if signedIn()
        && hasOnlyShopFields()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.planType in ['free', 'pro'];

      allow update: if isSalonAdmin(shopId)
        && hasOnlyUpdatedShopFields()
        && request.resource.data.planType in ['free', 'pro'];

      allow delete: if isSalonAdmin(shopId);

      match /reservations/{reservationId} {
        allow read: if isSalonAdmin(shopId);
        allow create: if isValidReservationCreate()
          && request.resource.data.shopId == shopId;
        allow update: if isSalonAdmin(shopId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
          && request.resource.data.status in ['pending', 'confirmed', 'completed', 'cancelled', '予約受付', '来店済み', 'キャンセル'];
        allow delete: if isSalonAdmin(shopId);
      }

      match /{document=**} {
        allow read, write: if isSalonAdmin(shopId);
      }
    }

    match /menus/{menuId} {
      allow read: if isSalonAdmin(resource.data.shopId)
        || (
          exists(/databases/$(database)/documents/shops/$(resource.data.shopId))
          && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.isWebPublished == true
        );
      allow create: if isSalonAdmin(request.resource.data.shopId) && hasOnlyMenuFields();
      allow update: if isSalonAdmin(resource.data.shopId)
        && request.resource.data.shopId == resource.data.shopId
        && hasOnlyMenuFields();
      allow delete: if isSalonAdmin(resource.data.shopId);
    }

    match /reservations/{reservationId} {
      allow read: if isSalonAdmin(resource.data.shopId);
      allow create: if isValidReservationCreate();
      allow update: if isSalonAdmin(resource.data.shopId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && request.resource.data.status in ['予約受付', '来店済み', 'キャンセル'];
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn() && request.auth.uid == userId;
    }
  }
}
