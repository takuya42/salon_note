rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSalonAdmin(shopId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/shops/$(shopId))
        && firestore.get(/databases/(default)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    match /shop_images/{shopId}/{fileName} {
      allow read: if fileName == 'shop_cover.jpg';
      allow write: if fileName == 'shop_cover.jpg'
        && isSalonAdmin(shopId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
